# Copiar a .env y rellenar. En Vercel: Project → Settings → Environment Variables.

# Base URL (pública)
NEXT_PUBLIC_URL=http://localhost:3000

# Crons (Vercel envía Authorization: Bearer <CRON_SECRET> en jobs programados)
CRON_SECRET=

# Base de datos — Supabase:
# - **Session pooler** (o conexión directa 5432): usar para Railway worker, `discover-*` largos en local, y
#   cuando veas "Connection terminated unexpectedly" con el pooler de transacciones.
# - **Transaction pooler** (6543): adecuado para funciones serverless cortas; puede cortar conexiones en
#   jobs HTTP largos (muchas queries seguidas).
# Price cache lives in PostgreSQL (`PriceCache` table). Remove legacy UPSTASH_REDIS_* from Vercel if present.
DATABASE_URL=

# Optional: scripts/discover-sports-local.ts — max Polymarket sport tags per run (default 25)
# DISCOVER_SPORTS_MAX_POLY_TAGS=25
# DISCOVER_SPORTS_BUDGET_MS=120000
# Optional: scripts/discover-local.ts — extra time budget (ms) on top of default DEADLINE_MS
# DISCOVER_DEADLINE_EXTRA_MS=0
# Optional: scripts/cleanup-markets.ts
# CLEANUP_INACTIVE_DAYS=7
# CLEANUP_RESOLVED_DAYS=7
# CLEANUP_SYNCLOG_DAYS=30

# NextAuth (Google)
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kalshi API (servidor)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

# Groq (matching semántico)
GROQ_API_KEY=

# Telegram: mismo valor que uses en setWebhook secret_token → TELEGRAM_WEBHOOK_SECRET
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Email (Resend, opcional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Donaciones (opcional)
NEXT_PUBLIC_BMC_DONATION_URL=
NEXT_PUBLIC_PAYPAL_DONATION_URL=
